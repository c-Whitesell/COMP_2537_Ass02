<%- include("components/header") %>

<div class="row justify-content-center">
  <div class="col-lg-8">
    <div class="card shadow-lg border-0 border-danger">
      <div class="card-body text-center py-5">
        <div style="font-size: 4rem; color: #dc3545; margin-bottom: 1rem;">
          <i class="fas fa-lock"></i>
        </div>
        
        <h1 class="display-4 mb-3" style="color: #dc3545; font-weight: bold;">Access Denied</h1>
        
        <h2 class="mb-3">403 - Unauthorized</h2>
        
        <p class="lead text-muted mb-5">
          You do not have permission to access this page. 
          Only administrators can view this content.
        </p>

        <div class="alert alert-warning">
          <i class="fas fa-info-circle"></i>
          If you believe this is a mistake, please contact an administrator.
        </div>

        <div class="d-grid gap-2 d-sm-flex justify-content-center">
          <a href="/" class="btn btn-primary btn-lg px-4">
            <i class="fas fa-home"></i> Go Home
          </a>
          <a href="/members" class="btn btn-outline-primary btn-lg px-4">
            <i class="fas fa-user"></i> Members Area
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include("components/footer") %>
