<%- include("components/header") %>

<div class="row justify-content-center">
  <div class="col-lg-8">
    <div class="card shadow-lg border-0">
      <div class="card-body text-center py-5">
        <div style="font-size: 4rem; color: #667eea; margin-bottom: 1rem;">
          <i class="fas fa-exclamation-triangle"></i>
        </div>
        
        <h1 class="display-1 mb-3" style="color: #667eea; font-weight: bold;">404</h1>
        
        <h2 class="mb-3">Page Not Found</h2>
        
        <p class="lead text-muted mb-5">
          Sorry! The page you're looking for doesn't exist or has been moved.
        </p>

        <div class="d-grid gap-2 d-sm-flex justify-content-center">
          <a href="/" class="btn btn-primary btn-lg px-4">
            <i class="fas fa-home"></i> Go Home
          </a>
          <a href="javascript:history.back()" class="btn btn-outline-primary btn-lg px-4">
            <i class="fas fa-arrow-left"></i> Go Back
          </a>
        </div>

        <hr class="my-5">

        <p class="text-muted">
          Need help? 
          <a href="/" class="text-decoration-none">Contact support</a>
        </p>
      </div>
    </div>
  </div>
</div>

<%- include("components/footer") %>
