<%- include("components/header", { name: typeof name !== 'undefined' ? name : undefined }) %>

<div class="row justify-content-center">
  <div class="col-lg-8">
    <% if (typeof name !== 'undefined') { %>
      <div class="card shadow-lg border-0">
        <div class="card-body text-center py-5">
          <h1 class="display-4 mb-4">
            <i class="fas fa-wave-hand" style="color: #667eea;"></i>
            Hello, <%= name %>!
          </h1>
          <p class="lead text-muted mb-4">Welcome back to your dashboard</p>
          
          <div class="d-grid gap-3">
            <a href="/members" class="btn btn-primary btn-lg">
              <i class="fas fa-users"></i> Go to Members Area
            </a>
            <a href="/admin" class="btn btn-secondary btn-lg">
              <i class="fas fa-user-shield"></i> Admin Panel
            </a>
            <a href="/logout" class="btn btn-danger btn-lg">
              <i class="fas fa-sign-out-alt"></i> Logout
            </a>
          </div>
        </div>
      </div>
    <% } else { %>
      <!-- Not Logged In Home Page -->
      <div class="card shadow-lg border-0">
        <div class="card-body text-center py-5">
          <h1 class="display-4 mb-2">Welcome!</h1>
          
          <div class="d-grid gap-3">
            <a href="/signup" class="btn btn-primary btn-lg">
              <i class="fas fa-user-plus"></i> Create Account
            </a>
            <a href="/login" class="btn btn-outline-primary btn-lg">
              <i class="fas fa-sign-in-alt"></i> Log In
            </a>
          </div>

          <hr class="my-5">

  
        </div>
      </div>
    <% } %>
  </div>
</div>

<%- include("components/footer") %>
