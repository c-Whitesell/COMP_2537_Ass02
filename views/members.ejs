<%- include("components/header", { name: name }) %>

<div class="row justify-content-center">
  <div class="col-lg-10">
    <div class="card shadow-lg border-0 mb-4">
      <div class="card-body text-center py-4">
        <h1 class="display-5 mb-2">
          <i class="fas fa-heart" style="color: #667eea;"></i>
          Hello, <%= name %>!
        </h1>
        <p class="lead text-muted">Check out our awesome collection</p>
      </div>
    </div>

    <h2 class="mb-4"><i class="fas fa-images" style="color: #667eea;"></i> Our Collection</h2>

    <!-- Responsive Image Grid -->
    <div class="row g-4 mb-5">
      <% images.forEach(image => { %>
        <div class="col-12 col-md-6 col-lg-4">
          <div class="card shadow-sm border-0 overflow-hidden h-100">
            <div class="position-relative overflow-hidden" style="height: 300px; background-color: #f0f0f0;">
              <img 
                src="/images/<%= image %>" 
                alt="Gallery image"
                class="w-100 h-100 object-fit-cover"
                style="object-fit: cover;"
              >
            </div>
            <div class="card-body text-center">
              <p class="text-muted mb-0">Image - <%= image %></p>
            </div>
          </div>
        </div>
      <% }) %>
    </div>

    <!-- Action Buttons -->
    <div class="card bg-light border-0">
      <div class="card-body text-center py-4">
        <a href="/" class="btn btn-outline-primary me-2">
          <i class="fas fa-home"></i> Back to Home
        </a>
        <a href="/logout" class="btn btn-danger">
          <i class="fas fa-sign-out-alt"></i> Logout
        </a>
      </div>
    </div>
  </div>
</div>

<%- include("components/footer") %>
