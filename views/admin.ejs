<%- include("components/header", { name: name }) %>

<div class="row justify-content-center">
  <div class="col-lg-11">
    <div class="card shadow-lg border-0 mb-4">
      <div class="card-body py-4">
        <h1 class="display-5 mb-2">
          <i class="fas fa-user-shield" style="color: #667eea;"></i>
          Admin Dashboard
        </h1>
        <p class="lead text-muted">Manage users and permissions</p>
      </div>
    </div>

    <div class="card shadow-lg border-0 mb-5">
      <div class="card-header bg-light">
        <h5 class="mb-0">
          <i class="fas fa-users"></i> All Users
        </h5>
      </div>
      <div class="card-body p-0">
        <% if (users && users.length > 0) { %>
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead class="table-light">
                <tr>
                  <th>Name</th>
                  <th>Email</th>
                  <th>Role</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% users.forEach(user => { %>
                  <%- include("components/user", { user: user }) %>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <div class="p-4 text-center text-muted">
            <i class="fas fa-users-slash fa-3x mb-3 d-block" style="opacity: 0.5;"></i>
            <p>No users found</p>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Info Section -->
    <div class="row">
      <div class="col-md-4 mb-3">
        <div class="card bg-primary text-white border-0">
          <div class="card-body text-center">
            <h3><i class="fas fa-users"></i></h3>
            <h4><%= users ? users.length : 0 %></h4>
            <p class="mb-0">Total Users</p>
          </div>
        </div>
      </div>
      <div class="col-md-4 mb-3">
        <div class="card bg-danger text-white border-0">
          <div class="card-body text-center">
            <h3><i class="fas fa-user-shield"></i></h3>
            <h4><%= users ? users.filter(u => u.user_type === 'admin').length : 0 %></h4>
            <p class="mb-0">Admins</p>
          </div>
        </div>
      </div>
      <div class="col-md-4 mb-3">
        <div class="card bg-info text-white border-0">
          <div class="card-body text-center">
            <h3><i class="fas fa-user"></i></h3>
            <h4><%= users ? users.filter(u => u.user_type === 'user').length : 0 %></h4>
            <p class="mb-0">Regular Users</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Back Button -->
    <div class="mt-4">
      <a href="/" class="btn btn-outline-primary">
        <i class="fas fa-arrow-left"></i> Back to Home
      </a>
    </div>
  </div>
</div>

<%- include("components/footer") %>

